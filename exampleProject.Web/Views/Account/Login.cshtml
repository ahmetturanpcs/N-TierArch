@model exampleProject.Web.Models.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Yönetim Paneli | Giriş Yap</title>

    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css">
    <link rel="stylesheet" href="~/dist/css/adminlte.min.css">

    <style>
            /* Modern, dinamik ve kurumsal bir arka plan gradyanı */
            body.login-page {
                background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            /* Giriş kutusunu cam efektiyle (Glassmorphism) modernleştiriyoruz */
            .login-box .card {
                background: rgba(255, 255, 255, 0.92);
                border: none;
                border-radius: 15px;
                box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
                backdrop-filter: blur(4px);
                -webkit-backdrop-filter: blur(4px);
                transition: all 0.3s ease;
            }

            /* Kutuya hafif bir havada asılı kalma (hover) efekti verelim */
            .login-box .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 12px 40px 0 rgba(0, 0, 0, 0.4);
            }

            /* Logo alanını beyaz yapıp parlatıyoruz */
            .login-logo a {
                color: #ffffff !important;
                text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
                font-weight: 300;
                letter-spacing: 1px;
            }
            .login-logo b {
                font-weight: 700;
            }

            /* Input alanlarının keskinliğini yumuşatıp odaklanma rengini özelleştiriyoruz */
            .form-control {
                border-radius: 8px 0 0 8px;
                border: 1px solid #ced4da;
                transition: all 0.3s ease;
            }
            .input-group-text {
                border-radius: 0 8px 8px 0;
                background-color: #f8f9fa;
            }
            .form-control:focus {
                border-color: #2a5298;
                box-shadow: none;
            }
            .form-control:focus + .input-group-append .input-group-text {
                border-color: #2a5298;
                color: #2a5298;
            }

            /* Butonu daha dolgun ve animasyonlu yapıyoruz */
            .btn-primary {
                background: linear-gradient(135deg, #2a5298 0%, #1e3c72 100%);
                border: none;
                border-radius: 8px;
                font-weight: 600;
                padding: 8px 20px;
                transition: all 0.3s ease;
            }
            .btn-primary:hover {
                background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
                transform: scale(1.02);
                box-shadow: 0 4px 15px rgba(42, 82, 152, 0.4);
            }

            /* Beni Hatırla checkbox'ını biraz daha estetik yapalım */
            .form-check-label {
                cursor: pointer;
                user-select: none;
                color: #6c757d;
                font-size: 0.95rem;
            }
            .form-check-input {
                cursor: pointer;
                margin-top: 5px;
            }
    </style>
</head>
<body class="hold-transition login-page">
    <div class="login-box">
        <div class="login-logo">
            <a href="#"><b>Admin</b>Panel</a>
        </div>
        <div class="card">
            <div class="card-body login-card-body rounded-lg">
                <p class="login-box-msg text-secondary font-weight-bold">Yönetim paneline erişmek için giriş yapın</p>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-1">
                        <div class="input-group">
                            <input asp-for="Email" type="email" class="form-control" placeholder="E-posta">
                            <div class="input-group-append">
                                <div class="input-group-text">
                                    <span class="fas fa-envelope"></span>
                                </div>
                            </div>
                        </div>
                        <span asp-validation-for="Email" class="text-danger small d-block mt-1 pl-1"></span>
                    </div>

                    <div class="mb-3 mt-2">
                        <div class="input-group">
                            <input asp-for="Password" type="password" class="form-control" placeholder="Şifre">
                            <div class="input-group-append">
                                <div class="input-group-text">
                                    <span class="fas fa-lock"></span>
                                </div>
                            </div>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small d-block mt-1 pl-1"></span>
                    </div>

                    <div class="row align-items-center mt-4">
                        <div class="col-7">
                            <div class="form-check pl-4">
                                <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="remember">
                                <label class="form-check-label" for="remember">Beni Hatırla</label>
                            </div>
                        </div>
                        <div class="col-5">
                            <button type="submit" class="btn btn-primary btn-block shadow-sm">
                                Giriş Yap <i class="fas fa-sign-in-alt ml-1"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/plugins/jquery/jquery.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/dist/js/adminlte.min.js"></script>
</body>
</html>