@using exampleProject.Core.Entities
@model List<Category>

@{
    ViewData["Title"] = "Kategori Listesi";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Yönetim Paneli - Kategoriler</h3>
                <div class="card-tools">
                    <button class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Yeni Kategori</button>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Kategori Adı</th>
                            <th>Açıklama</th>
                            <th>Durum</th>
                            <th>Kayıt Tarihi</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td><strong>@item.Name</strong></td>
                                <td>@item.Description</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge badge-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Pasif</span>
                                    }
                                </td>
                                <td>@item.CreatedDate.ToShortDateString()</td>
                                <td>
                                    <button class="btn btn-info btn-sm"><i class="fas fa-pencil-alt"></i> Düzenle</button>
                                    <button class="btn btn-danger btn-sm"><i class="fas fa-trash"></i> Sil</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>